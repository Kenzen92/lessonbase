# Ensure shell scripts always use LF line endings
*.sh text eol=lf

# Also enforce LF for common text files
*.py text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf
*.txt text eol=lf

# Prevent accidental conversion of binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.exe binary
