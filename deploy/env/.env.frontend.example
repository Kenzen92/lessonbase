# Production Environment Variables
# Copy this to .env.production and fill in your values

# Use your production API URL (e.g., https://backend-late-haze-5388.fly.dev)
VITE_REACT_APP_API_URL=https://your-backend-domain.com

# WebSocket URL - use wss:// for secure websockets in production
# Or use relative path '/ws' to auto-detect from current domain
VITE_REACT_APP_WEBSOCKET_URL=/ws

# Your Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
