# VPS Production Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Docker Hub Configuration
# ============================================
DOCKER_USERNAME=your_docker_hub_username

# ============================================
# PostgreSQL Database Configuration
# ============================================
POSTGRES_DB=kennysolutions_db
POSTGRES_USER=kennysolutions_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ============================================
# Django Configuration
# ============================================
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_WITH_DJANGO_COMMAND
SECRET_KEY=CHANGE_ME_SAME_AS_DJANGO_SECRET_KEY

# To generate secret key:
# python3 -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'

# ============================================
# Application URLs
# ============================================
FRONTEND_URL=https://teach.jkenny.tech
BASE_URL=https://api.teach.jkenny.tech

# ============================================
# CORS & Allowed Hosts (Optional overrides)
# ============================================
# These are set in settings.py but can be overridden here
# ALLOWED_HOSTS=api.teach.jkenny.tech,teach.jkenny.tech
# CORS_ALLOWED_ORIGINS=https://teach.jkenny.tech

# ============================================
# External API Services
# ============================================
OPENAI_API_KEY=your_openai_api_key_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ============================================
# MongoDB Configuration (if still using)
# ============================================
MONGO_USERNAME=your_mongo_atlas_username
MONGO_PASSWORD=your_mongo_atlas_password
MONGO_DB_NAME=kennysolutions
MONGO_PORT=27017

# ============================================
# Email Configuration (Gmail SMTP)
# ============================================
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password

# To create Gmail app password:
# 1. Go to Google Account Settings
# 2. Security → 2-Step Verification
# 3. App passwords → Generate

# ============================================
# Application Environment
# ============================================
ENVIRONMENT=production

# ============================================
# Optional: Database URL (for compatibility)
# ============================================
# If you prefer DATABASE_URL over individual vars
# DATABASE_URL=postgresql://user:password@db:5432/dbname
